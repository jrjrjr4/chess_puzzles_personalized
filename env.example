# Chess Puzzles Personalized - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# FLASK CONFIGURATION
# =============================================================================

# Secret key for session encryption (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-random-string

# =============================================================================
# DATABASE (SUPABASE)
# =============================================================================

# Supabase project URL (from Settings > API)
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Supabase anon/public key (from Settings > API)
# Starts with: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_KEY=

# =============================================================================
# OAUTH - LICHESS (Optional)
# =============================================================================

# Lichess OAuth client ID
# Get from: https://lichess.org/account/oauth/app
# No client secret needed (uses PKCE)
LICHESS_CLIENT_ID=

# =============================================================================
# OAUTH - GOOGLE (Optional)
# =============================================================================

# Google OAuth credentials
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Base URL for OAuth redirects
# Development: http://localhost:5000
# Production: https://your-domain.com
BASE_URL=http://localhost:5000

# Admin API key for bulk operations (optional)
# Used for /api/admin/reset-all-ratings endpoint
ADMIN_KEY=

# =============================================================================
# NOTES
# =============================================================================

# The app will work without Supabase credentials, but:
# - User accounts won't persist
# - Ratings won't be saved
# - Puzzle attempts won't be recorded

# OAuth providers are optional:
# - Without Lichess: "Login with Lichess" won't appear
# - Without Google: "Login with Google" won't appear
# - Without both: App works but no login functionality

# For production, also set in your Flask app:
# - SESSION_COOKIE_SECURE = True (requires HTTPS)
# - Debug mode = False

